{
  "compilerOptions": {
    "types": ["jest"],
    "target": "ES6",
    "module": "commonjs",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "outDir": "../dist",
    "rootDir": "."
  },
  "include": [
    "**/index.ts"
  ],
  "exclude": [
    "node_modules",
    "**/*.test.ts"
  ]
}


